<odoo>
    <template id="compliance_footer_links" inherit_id="website.layout" priority="100">
        <!-- [@ANCHOR: compliance_footer_links] -->

        <!-- audit-ignore-xpath: Tested by [@ANCHOR: test_compliance_ui_tour] -->
        <xpath expr="//div[hasclass('o_footer_copyright')]" position="inside">
            <div class="col-sm text-center text-sm-start small">
                <a href="/privacy" class="me-3 o_tour_footer_privacy">Privacy Policy</a>
                <a href="/cookie-policy" class="me-3 o_tour_footer_cookie_policy">Cookie Policy</a>
                <a href="/terms" class="me-3 o_tour_footer_terms">Terms of Service</a>
                <a href="/accessibility" class="me-3 o_tour_footer_accessibility">Accessibility Statement</a>
                <a href="/my/privacy" class="me-3 o_tour_footer_my_privacy">My Privacy</a>
            </div>
        </xpath>
    </template>
</odoo>
