<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="compliance_footer_links" inherit_id="website.layout" priority="100">
        <!-- [@ANCHOR: compliance_footer_links] -->
        <!-- audit-ignore-xpath -->
        <xpath expr="//div[hasclass('o_footer_copyright')]//div[hasclass('row')]" position="inside">
            <div class="col-sm text-center text-sm-start small">
                <a href="/privacy" class="me-3">Privacy Policy</a>
                <a href="/cookie-policy" class="me-3">Cookie Policy</a>
                <a href="/terms" class="me-3">Terms of Service</a>
                <a href="/accessibility" class="me-3">Accessibility Statement</a>
                <a href="/my/privacy">My Privacy</a>
            </div>
        </xpath>
    </template>
</odoo>
