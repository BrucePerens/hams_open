<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_compliance" model="res.groups.privilege">
            <field name="name">Global Compliance</field>
            <field name="category_id" ref="base.module_category_website"/>
        </record>

        <record id="group_compliance_service" model="res.groups">
            <!-- [@ANCHOR: COMM_compliance_security_acls] -->
            <field name="name">Micro-Privilege: Compliance Service</field>
            <field name="privilege_id" ref="res_groups_privilege_compliance"/>
        </record>
    </data>
    <data noupdate="0">
        <record id="user_compliance_service" model="res.users">
            <field name="name">Compliance Service Account</field>
            <field name="login">user_compliance_service</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('compliance.group_compliance_service')])]"/>
        </record>
    </data>
</odoo>
