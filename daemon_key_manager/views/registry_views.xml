<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daemon_key_registry_tree" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_ui_rendering] -->

        <!-- Verified by [@ANCHOR: COMM_test_daemon_key_manager_tour] -->
        <field name="name">daemon.key.registry.tree</field>
        <field name="model">daemon.key.registry</field>
        <field name="arch" type="xml">
            <list string="Daemon Key Registry">
                <field name="name"/>
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="env_file_path"/>
                <field name="last_rotated"/>
            </list>
        </field>
    </record>

    <record id="view_daemon_key_registry_form" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_ui_rendering] -->

        <!-- Verified by [@ANCHOR: COMM_test_daemon_key_manager_tour] -->
        <field name="name">daemon.key.registry.form</field>
        <field name="model">daemon.key.registry</field>
        <field name="arch" type="xml">
            <form string="Daemon Key Registry">
                <header>
                    <button name="action_rotate_key" type="object" string="Rotate Key" class="oe_highlight" invisible="not id"/>
                    <button name="action_force_provision_all" type="object" string="Force Provision All" invisible="not id"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="user_id" domain="[('is_service_account', '=', True)]"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="env_file_path"/>
                            <field name="last_rotated"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_daemon_key_registry" model="ir.actions.act_window">
        <field name="name">Daemon Key Registry</field>
        <field name="res_model">daemon.key.registry</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_server_force_provision_all" model="ir.actions.server">
        <field name="name">Force Provision All Keys</field>
        <field name="model_id" ref="model_daemon_key_registry"/>
        <field name="binding_model_id" ref="model_daemon_key_registry"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = model.action_force_provision_all()</field>
    </record>

    <menuitem id="menu_daemon_key_registry"
              name="Daemon Key Registry"
              parent="base.menu_users"
              action="action_daemon_key_registry"
              sequence="100"/>
</odoo>
