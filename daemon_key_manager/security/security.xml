<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_daemon_key_manager" model="res.groups.privilege">
            <field name="name">Daemon Key Management</field>
            <field name="category_id" ref="base.module_category_administration"/>
        </record>

        <record id="group_daemon_key_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_daemon_key_manager"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Users with this privilege can manage API keys for background daemons.</field>
        </record>

        <record id="group_daemon_key_usage" model="res.groups">
            <field name="name">Daemon Key Usage</field>
            <field name="privilege_id" ref="res_groups_privilege_daemon_key_manager"/>
            <field name="api_key_duration">90</field>
            <field name="comment">This group allows service accounts to have API keys with a 90-day duration.</field>
        </record>

        <record id="daemon_key_registry_company_rule" model="ir.rule">
            <field name="name">Daemon Key Registry multi-company</field>
            <field name="model_id" ref="model_daemon_key_registry"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="daemon_key_manager_all_companies_rule" model="ir.rule">
            <field name="name">Daemon Key Manager cross-company</field>
            <field name="model_id" ref="model_daemon_key_registry"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('daemon_key_manager.group_daemon_key_manager'))]"/>
        </record>

        <record id="daemon_key_manager_read_service_accounts_rule" model="ir.rule">
            <field name="name">Daemon Key Manager can read Service Accounts</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('daemon_key_manager.group_daemon_key_manager'))]"/>
        </record>
    </data>
    <data>
        <record id="user_daemon_key_manager_service" model="res.users">
            <field name="name">Daemon Key Manager Service</field>
            <field name="login">daemon_key_manager_service</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(4, ref('daemon_key_manager.group_daemon_key_manager'))]"/>
        </record>
    </data>
</odoo>
