<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_real_transaction" model="res.groups.privilege">
            <field name="name">Real Transaction Management</field>
            <field name="description">Allows managing Real Transaction Testing Facility</field>
        </record>

        <record id="group_real_transaction_manager" model="res.groups">
            <field name="name">Real Transaction Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_real_transaction"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Service Account for Documentation and Background Tasks -->
        <!-- [@ANCHOR: user_real_transaction_service] -->
        <record id="user_real_transaction_service" model="res.users">
            <field name="name">Real Transaction Service Account</field>
            <field name="login">user_real_transaction_service</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('group_real_transaction_manager')])]"/>
        </record>
    </data>
</odoo>
