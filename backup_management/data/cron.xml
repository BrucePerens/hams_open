<odoo>
    <data noupdate="1">
        <record id="cron_sync_backups" model="ir.cron">
            <!-- audit-ignore-cron: Tested by [@ANCHOR: backup_management:COMM_test_backup_cron] -->
            <field name="name">Backup Management: Sync Snapshots</field>
            <field name="model_id" ref="model_backup_config"/>
            <field name="user_id" ref="user_backup_service_internal"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_all_backups()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
