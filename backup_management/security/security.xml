<odoo>
    <data noupdate="1">
        <record id="group_backup_admin" model="res.groups">
            <field name="name">Backup Administrator</field>
        </record>
        <record id="group_backup_service_account" model="res.groups">
            <field name="name">Backup Service Account</field>
        </record>
    </data>
    <data noupdate="0">
        <record id="user_backup_service_internal" model="res.users">
            <field name="name">Backup Service Internal</field>
            <field name="login">backup_service_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('backup_management.group_backup_admin'), ref('backup_management.group_backup_service_account')])]"/>
        </record>

    </data>
    <data noupdate="1">
        <record id="rule_backup_config_multi_tenant" model="ir.rule">
            <field name="name">Backup Config Multi-Tenant</field>
            <field name="model_id" ref="model_backup_config"/>
            <field name="domain_force">[('company_id', 'in', company_ids), '|', ('website_id', '=', False), ('website_id', '=', user.website_id.id)]</field>
            <field name="groups" eval="[(4, ref('backup_management.group_backup_admin'))]"/>
        </record>

        <record id="rule_backup_snapshot_multi_tenant" model="ir.rule">
            <field name="name">Backup Snapshot Multi-Tenant</field>
            <field name="model_id" ref="model_backup_snapshot"/>
            <field name="domain_force">[('company_id', 'in', company_ids), '|', ('config_id.website_id', '=', False), ('config_id.website_id', '=', user.website_id.id)]</field>
            <field name="groups" eval="[(4, ref('backup_management.group_backup_admin'))]"/>
        </record>

        <record id="rule_backup_job_multi_tenant" model="ir.rule">
            <field name="name">Backup Job Multi-Tenant</field>
            <field name="model_id" ref="model_backup_job"/>
            <field name="domain_force">[('company_id', 'in', company_ids), '|', ('website_id', '=', False), ('website_id', '=', user.website_id.id)]</field>
            <field name="groups" eval="[(4, ref('backup_management.group_backup_admin'))]"/>
        </record>

        <record id="rule_backup_latest_snapshot_view_multi_tenant" model="ir.rule">
            <field name="name">Backup Latest Snapshot View Multi-Tenant</field>
            <field name="model_id" ref="model_backup_latest_snapshot_view"/>
            <field name="domain_force">[('company_id', 'in', company_ids), '|', ('website_id', '=', False), ('website_id', '=', user.website_id.id)]</field>
            <field name="groups" eval="[(4, ref('backup_management.group_backup_admin'))]"/>
        </record>
    </data>
</odoo>
