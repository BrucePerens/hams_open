    <menuitem id="menu_backup_snapshot" name="Snapshots" parent="menu_backup_root" action="action_backup_snapshot" sequence="20"/>
    <menuitem id="menu_backup_job" name="Active Jobs" parent="menu_backup_root" action="action_backup_job" sequence="15"/>
