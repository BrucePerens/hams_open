<odoo>
    <menuitem id="menu_admin_root" name="Backups" sequence="70" groups="backup_management.group_backup_admin"/>

    <record id="action_backup_config" model="ir.actions.act_window">
        <field name="name">Backup Configurations</field>
        <field name="res_model">backup.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_backup_snapshot" model="ir.actions.act_window">
