<odoo>
    <record id="view_backup_config_list" model="ir.ui.view">
        <!-- Verified by [@ANCHOR: backup_management:backup_dashboard_tour] -->
        <field name="name">backup.config.list</field>
        <field name="model">backup.config</field>
        <field name="arch" type="xml">
            <list string="Backup Configurations">
                <field name="name"/>
                <field name="website_id" groups="website.group_multi_website"/>
                <field name="engine"/>
                <field name="target_path"/>
            </list>
        </field>
    </record>

    <record id="view_backup_config_form" model="ir.ui.view">
        <!-- Verified by [@ANCHOR: backup_management:backup_dashboard_tour] -->
        <field name="name">backup.config.form</field>
        <field name="model">backup.config</field>
        <field name="arch" type="xml">
            <form string="Backup Configuration">
                <header>
                    <button name="action_trigger_backup" type="object" string="Run Backup Now" class="oe_highlight" invisible="not id"/>
                    <button name="action_test_connection" type="object" string="Test Connection" class="btn-secondary" invisible="not id"/>
                    <button name="action_apply_policies" type="object" string="Apply Policies" class="btn-warning" invisible="not id or engine != 'kopia'"/>
                    <button name="action_sync_snapshots" type="object" string="Sync Snapshots" class="btn-secondary" invisible="not id"/>
                    <button name="action_view_latest_job" type="object" string="View Latest Job" class="btn-link" invisible="not id"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Kopia Main Repo"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="engine"/>
                            <field name="website_id" groups="website.group_multi_website"/>
                            <field name="target_path"/>
                            <field name="minimum_size_mb"/>
                            <field name="kopia_password" password="True" invisible="engine != 'kopia'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Storage Backend">
                            <group>
                                <field name="storage_type"/>
                                <field name="endpoint_url" invisible="storage_type == 'local'"/>
                                <field name="bucket_name" invisible="storage_type == 'local'"/>
                                <field name="access_key" invisible="storage_type == 'local'"/>
                                <field name="secret_key" password="True" invisible="storage_type == 'local'"/>
                            </group>
                        </page>
                        <page string="Retention Policies">
                            <group>
                                <field name="keep_daily"/>
                                <field name="keep_weekly"/>
                                <field name="keep_monthly"/>
                            </group>
                        </page>
                        <page string="Exclusions" invisible="engine != 'kopia'">
                            <group>
                                <field name="exclude_patterns" widget="text"/>
                            </group>
                        </page>
                        <page string="Automated Drills">
                            <group>
                                <field name="restore_drill_script"/>
                                <field name="last_drill_time"/>
                            </group>
                        </page>
                        <page string="Snapshots">
                            <field name="snapshot_ids" readonly="1">
                                <list>
                                    <field name="snapshot_id"/>
                                    <field name="start_time"/>
                                    <field name="size_bytes"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
