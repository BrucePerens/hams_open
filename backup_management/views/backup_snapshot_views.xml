<odoo>
    <record id="view_backup_snapshot_list" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: backup_management:test_backup_view] -->
        <field name="name">backup.snapshot.list</field>
        <field name="model">backup.snapshot</field>
        <field name="arch" type="xml">
            <list string="Snapshots" create="false" edit="false">
                <field name="config_id"/>
                <field name="snapshot_id"/>
                <field name="start_time"/>
                <field name="size_bytes"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_backup_snapshot_form" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: backup_management:test_backup_view] -->
        <field name="name">backup.snapshot.form</field>
        <field name="model">backup.snapshot</field>
        <field name="arch" type="xml">
            <form string="Snapshot" create="false" edit="false">
                <header>
                    <button name="%(backup_management.action_backup_restore_wizard)d" type="action" string="Restore Snapshot" class="btn-warning" context="{'default_snapshot_id': id}"/>
                </header>
                <sheet>

                    <group>
                        <group>
                            <field name="config_id"/>
                            <field name="snapshot_id"/>
                            <field name="start_time"/>
                        </group>
                        <group>
                            <field name="size_bytes"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <group>
                        <separator string="Restoration Assistance"/>
                        <div class="alert alert-warning" role="alert">
                            <strong>Warning:</strong> Restoration is a destructive process. Execute the command below in your server terminal.
                        </div>
                        <field name="restore_command" widget="CopyClipboardChar" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
