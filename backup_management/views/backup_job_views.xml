<odoo>
    <record id="view_backup_job_form" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: backup_management:test_backup_view] -->
        <field name="name">backup.job.form</field>
        <field name="model">backup.job</field>
        <field name="arch" type="xml">
            <form string="Backup Job" create="false" edit="false">
                <header>
                    <button name="action_refresh_status" string="Refresh Status" type="object" invisible="state in ['done', 'failed']" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,processing,done,failed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="job_type" readonly="1"/> Backup Task</h1>
                    </div>
                    <group>
                        <group>
                            <field name="config_id" readonly="1"/>
                            <field name="website_id" readonly="1" groups="website.group_multi_website"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Live Output Log">
                            <field name="output_log" widget="text" class="font-monospace text-muted p-2 bg-light border rounded" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_backup_job_list" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: backup_management:test_backup_view] -->
        <field name="name">backup.job.list</field>
        <field name="model">backup.job</field>
        <field name="arch" type="xml">
            <list string="Backup Jobs" create="false" edit="false" decoration-info="state == 'processing'" decoration-success="state == 'done'" decoration-danger="state == 'failed'">
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="website_id" groups="website.group_multi_website"/>
                <field name="job_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_backup_job" model="ir.actions.act_window">
        <field name="name">Backup Jobs (Active)</field>
        <field name="res_model">backup.job</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="ir_cron_auto_refresh_backup_jobs" model="ir.cron">
        <!-- audit-ignore-cron: Tested by [@ANCHOR: backup_management:test_backup_cron] -->
        <field name="name">Backup Job Auto-Refresh</field>
        <field name="model_id" ref="model_backup_job"/>
        <field name="state">code</field>
        <field name="code">model._auto_refresh_status()</field>
        <field name="user_id" ref="backup_management.user_backup_service_internal"/>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
    </record>
</odoo>
