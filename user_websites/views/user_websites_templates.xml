<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="user_navbar" name="User Websites Navbar">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <nav t-if="resolved_slug" class="navbar navbar-expand-lg navbar-light bg-light border-bottom user-websites-navbar">
            <div class="container">
                <a class="navbar-brand" t-attf-href="/#{resolved_slug}/home">
                    <t t-if="profile_user">
                        <img t-attf-src="/web/image/res.users/#{profile_user.id}/avatar_128?unique=#{profile_user.write_date and int(profile_user.write_date.timestamp()) or 0}" width="30" height="30" class="d-inline-block align-top rounded-circle me-2" alt="User Avatar"/>
                        <t t-out="profile_user.name"/>
                    </t>
                    <t t-elif="profile_group">
                        <i class="fa fa-users me-2" aria-hidden="true"/> <t t-out="profile_group.name"/>
                    </t>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#userNavbarNav" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="userNavbarNav">
                    <ul class="navbar-nav me-auto" id="user_navbar_nav_links">
                        <li class="nav-item">
                            <a class="nav-link" t-attf-href="/#{resolved_slug}/home">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" t-attf-href="/#{resolved_slug}/blog">Blog</a>
                        </li>
                    </ul>
                    <div id="user_websites_dropzone_navbar_actions">
                        <!-- [@ANCHOR: dropzone_navbar_actions] -->

                        <!-- Tested by [@ANCHOR: test_dropzone_navbar_actions] -->
                    </div>
                </div>
            </div>
        </nav>
    </template>

    <template id="layout_inherit_user_navbar" inherit_id="website.layout" name="User Navbar Global">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <xpath expr="//head" position="inside">
            <!-- [@ANCHOR: xpath_rendering_navbar_head] -->

            <!-- audit-ignore-xpath: Tested by [@ANCHOR: test_xpath_rendering_navbar_head] -->
            <t t-set="profile_user" t-value="profile_user or (main_object.owner_user_id if main_object and 'owner_user_id' in main_object else False)"/>
            <t t-set="profile_group" t-value="profile_group or (main_object.user_websites_group_id if main_object and 'user_websites_group_id' in main_object else False)"/>
            <t t-set="resolved_slug" t-value="resolved_slug or (profile_user.website_slug if profile_user else (profile_group.website_slug if profile_group else False))"/>
            <t t-set="page_type" t-value="page_type or ('blog' if 'blog' in request.httprequest.path else 'home')"/>
            <t t-set="is_owner" t-value="is_owner or (profile_user and profile_user.id == uid) or (profile_group and uid in profile_group.member_ids.ids)"/>

            <t t-if="resolved_slug">
                <meta name="user_websites_slug" t-att-content="resolved_slug"/>
            </t>
        </xpath>

        <xpath expr="//header" position="after">
            <!-- [@ANCHOR: xpath_rendering_navbar] -->

            <!-- audit-ignore-xpath: Tested by [@ANCHOR: test_xpath_rendering_navbar] -->
            <div id="user_websites_dropzone_navbar">
                <!-- [@ANCHOR: dropzone_navbar] -->

                <!-- Tested by [@ANCHOR: test_dropzone_navbar] -->
            </div>
            <t t-if="resolved_slug">
                <t t-call="user_websites.user_navbar"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_home_appeal" inherit_id="portal.portal_my_home" name="Portal My Home Appeal">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <xpath expr="//div[hasclass('o_portal_my_home')]" position="before">
            <!-- [@ANCHOR: xpath_rendering_appeal] -->

            <!-- audit-ignore-xpath: Tested by [@ANCHOR: test_xpath_rendering_appeal] -->
            <div id="user_websites_dropzone_templates">
                <!-- [@ANCHOR: dropzone_templates] -->

                <!-- Tested by [@ANCHOR: test_dropzone_templates] -->
            </div>
            <div class="container mt-4">
                <t t-if="user_id.is_suspended_from_websites">
                    <div class="alert alert-danger shadow-sm" role="alert">
                        <h4 class="alert-heading fw-bold"><i class="fa fa-ban me-2" aria-hidden="true"/> Account Suspended <a href="/user-websites/documentation#UX_SUBMIT_APPEAL" class="text-info fs-5 ms-1" title="Help"><i class="fa fa-question-circle" aria-hidden="true"/></a></h4>
                        <p>We suspended your website and blog features because of community guideline violations. We also unpublished your content.</p>
                        <hr/>

                        <t t-set="existing_appeal" t-value="user_id.appeal_ids.filtered(lambda a: a.state == 'new')"/>

                        <t t-if="existing_appeal">
                            <p class="mb-0 text-dark fw-bold"><i class="fa fa-clock-o me-1" aria-hidden="true"/> We are currently reviewing your appeal.</p>
                        </t>
                        <t t-else="">
                            <form action="/website/submit_appeal" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="mb-3">
                                    <label for="reason" class="form-label fw-bold">Submit an Appeal (One-time only):</label>
                                    <textarea class="form-control" name="reason" id="reason" rows="3" required="required" placeholder="Please explain why your suspension should be lifted..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-danger">Submit Appeal</button>
                            </form>
                        </t>
                    </div>
                </t>
                
                <t t-set="suspended_groups" t-value="user_id.suspended_group_ids"/>
                <t t-foreach="suspended_groups" t-as="group">
                    <div class="alert alert-danger shadow-sm mt-3" role="alert">
                        <h4 class="alert-heading fw-bold"><i class="fa fa-ban me-2" aria-hidden="true"/> Group Suspended: <t t-out="group.name"/></h4>
                        <p>We suspended this group's website and blog features because of community guideline violations. We also unpublished the group's content.</p>
                        <hr/>

                        <t t-set="existing_appeal" t-value="group.appeal_ids.filtered(lambda a: a.state == 'new')"/>

                        <t t-if="existing_appeal">
                            <p class="mb-0 text-dark fw-bold"><i class="fa fa-clock-o me-1" aria-hidden="true"/> We are currently reviewing the group's appeal.</p>
                        </t>
                        <t t-else="">
                            <form action="/website/submit_appeal" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input type="hidden" name="group_id" t-att-value="group.id"/>
                                <div class="mb-3">
                                    <label t-attf-for="reason_#{group.id}" class="form-label fw-bold">Submit an Appeal for this Group (One-time only):</label>
                                    <textarea class="form-control" name="reason" t-attf-id="reason_#{group.id}" rows="3" required="required" placeholder="Please explain why the group's suspension should be lifted..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-danger">Submit Appeal</button>
                            </form>
                        </t>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <!-- [@ANCHOR: xpath_rendering_portal_docs] -->

            <!-- audit-ignore-xpath: Tested by [@ANCHOR: test_xpath_rendering_portal_docs] -->
            <div class="o_portal_doc_spinner col-12 col-md-6 col-lg-4 mb-4">
                <a href="/my/privacy" class="text-decoration-none d-flex flex-column h-100 p-3 border rounded shadow-sm bg-white">
                    <div class="d-flex align-items-center mb-2">
                        <i class="fa fa-shield fa-2x text-primary me-3" aria-hidden="true"/>
                        <h5 class="mb-0 fw-bold text-dark">Privacy &amp; Data</h5>
                    </div>
                    <div class="text-muted small">Manage your data, export content, and right to erasure.</div>
                </a>
            </div>
        </xpath>
    </template>

    <template id="portal_my_privacy" name="My Privacy &amp; Data">
        <!-- Tested by [@ANCHOR: user_websites:test_tour_gdpr_privacy] -->
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Privacy &amp; Data</t>
            </t>
            <div class="container mt-4 mb-5">
                <div class="row">
                    <div class="col-12 col-lg-8 mx-auto">
                        <h2 class="fw-bold mb-4">Privacy &amp; Data Management</h2>

                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body">
                                <h4 class="card-title fw-bold"><i class="fa fa-download text-primary me-2" aria-hidden="true"/> Download My Data <a href="/user-websites/documentation#UX_GDPR_EXPORT" class="text-info fs-5 ms-1" title="Help"><i class="fa fa-question-circle" aria-hidden="true"/></a></h4>
                                <p class="text-muted">Get a copy of your personal website pages and blog posts in a machine-readable JSON format for data portability purposes.</p>
                                <form action="/my/privacy/export" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-outline-primary"><i class="fa fa-download" aria-hidden="true"/> Export Data to JSON</button>
                                </form>
                            </div>
                        </div>

                        <div class="card shadow-sm border-0 border-danger border border-1">
                            <div class="card-body">
                                <h4 class="card-title fw-bold text-danger"><i class="fa fa-trash text-danger me-2" aria-hidden="true"/> Right to Erasure <a href="/user-websites/documentation#UX_GDPR_ERASURE" class="text-info fs-5 ms-1" title="Help"><i class="fa fa-question-circle" aria-hidden="true"/></a></h4>
                                <p class="text-muted">Permanently delete all of your personal website pages and blog posts. This action also removes you from the public community directory. <strong>This cannot be undone.</strong></p>
                                <form action="/my/privacy/delete_content" method="post" onsubmit="return confirm('Are you absolutely sure you want to permanently delete all your content? This cannot be undone.');">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-danger o_tour_erasure_initiate"><i class="fa fa-warning" aria-hidden="true"/> Delete All My Content</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="template_default_home" name="User Website Home Master Layout">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <t t-call="website.layout">
            <div id="user_websites_dropzone_home_header">
                <!-- [@ANCHOR: dropzone_home_header] -->

                <!-- Tested by [@ANCHOR: test_dropzone_home_header] -->
            </div>

            <t t-out="0"/>

            <div id="user_websites_dropzone_home_footer">
                <!-- [@ANCHOR: dropzone_home_footer] -->

                <!-- Tested by [@ANCHOR: test_dropzone_home_footer] -->
            </div>
        </t>
    </template>

    <template id="blog_index" name="User Blog Index">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <t t-call="website.layout">
            <div id="user_websites_dropzone_blog_header"></div>
            <div class="container mt-5">
                <t t-set="entity_name" t-value="profile_user.name if profile_user else (profile_group.name if profile_group else '')"/>
                <h1 class="mb-4"><t t-out="entity_name"/>'s Blog</h1>
                <t t-if="not posts">
                    <p class="text-muted">No posts available yet.</p>
                </t>
                <t t-else="">
                    <t t-foreach="posts" t-as="post">
                        <div class="card mb-4 shadow-sm border-0">
                            <div class="card-body">
                                <h3 class="card-title fw-bold" t-out="post.name"/>
                                <p class="text-muted" t-if="post.subtitle" t-out="post.subtitle"/>
                                <a t-attf-href="/blog/#{post.blog_id.id}/post/#{post.id}" class="btn btn-outline-primary mt-2">Read Post</a>
                            </div>
                        </div>
                    </t>
                </t>
                <div class="d-flex justify-content-center mt-4 mb-4">
                    <t t-call="website.pager"/>
                </div>
            </div>
            <div id="user_websites_dropzone_blog_footer"></div>
        </t>
    </template>

    <template id="community_directory" name="Community Directory">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h1 class="display-4 fw-bold">Community Directory <a href="/user-websites/documentation#UX_COMMUNITY_DIRECTORY" class="text-info fs-5 ms-2" title="Help"><i class="fa fa-question-circle" aria-hidden="true"/></a></h1>
                        <p class="lead text-muted">Discover and connect with websites created by our amazing community members.</p>
                        <hr class="w-25 mx-auto"/>
                    </div>
                </div>
                <div class="row mt-4">
                    <t t-foreach="entries" t-as="entry">
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm border-0 hover-lift transition-all">
                                <div class="card-body p-4 text-center">
                                    <div class="mb-4">
                                        <img t-attf-src="/web/image/res.users/#{entry.user_id.id}/avatar_128?unique=#{entry.user_id.write_date and int(entry.user_id.write_date.timestamp()) or 0}" class="rounded-circle img-thumbnail shadow-sm p-1" style="width: 100px; height: 100px; object-fit: cover;" alt="User Avatar"/>
                                    </div>
                                    <h4 class="card-title fw-bold mb-2" t-out="entry.name"/>
                                    <p class="text-muted small mb-4">
                                        <span class="badge bg-light text-dark border py-2 px-3">
                                            <i class="fa fa-eye me-1 text-primary" aria-hidden="true"/> <t t-out="entry.view_count"/> Total Views
                                        </span>
                                    </p>
                                    <div class="d-grid gap-2">
                                        <a t-attf-href="/#{entry.website_slug}/home" class="btn btn-primary py-2 fw-bold">
                                            <i class="fa fa-home me-2" aria-hidden="true"/> Visit Home
                                        </a>
                                        <a t-attf-href="/#{entry.website_slug}/blog" class="btn btn-outline-secondary py-2 fw-bold">
                                            <i class="fa fa-pencil me-2" aria-hidden="true"/> View Blog
                                        </a>
                                    </div>
                                    <div id="user_websites_dropzone_directory_card" class="mt-3">
                                        <!-- [@ANCHOR: dropzone_directory_card] -->

                                        <!-- Tested by [@ANCHOR: test_dropzone_directory_card] -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                    <div t-if="not entries" class="col-12">
                        <p class="text-muted">No public websites available yet.</p>
                    </div>
                </div>
                <div class="d-flex justify-content-center mt-4 mb-4">
                    <t t-call="website.pager"/>
                </div>
            </div>
        </t>
    </template>

    <template id="report_violation_modal" name="Report Violation Modal">
        <!-- Tested by [@ANCHOR: user_websites:test_tour_frontend_misc] -->
        <div class="modal fade" id="reportViolationModal" tabindex="-1" role="dialog" aria-labelledby="reportViolationModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <form action="/website/report_violation" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="url" t-att-value="request.httprequest.url"/>

                        <div class="modal-header">
                            <h5 class="modal-title fw-bold" id="reportViolationModalLabel">Report Content Violation <a href="/user-websites/documentation#UX_REPORT_VIOLATION" class="text-info fs-5 ms-2" title="Help"><i class="fa fa-question-circle" aria-hidden="true"/></a></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">

                            <div class="mb-3 d-none" aria-hidden="true">
                                <label for="website_honeypot">Leave this field empty if you are human:</label>
                                <input type="text" class="form-control" name="website_honeypot" id="website_honeypot" tabindex="-1" autocomplete="off"/>
                            </div>

                            <t t-if="is_public_user">
                                <div class="mb-3">
                                    <label for="email" class="form-label">Your Email Address:</label>
                                    <input type="email" class="form-control" name="email" id="email" required="required" placeholder="name@example.com"/>
                                </div>
                            </t>

                            <div class="mb-3">
                                <label for="description" class="form-label">Reason for reporting:</label>
                                <textarea class="form-control" name="description" id="description" rows="3" required="required"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger">Submit Report</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </template>

    <template id="report_violation_snippet" name="Report Violation Button">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <div class="text-center user-websites-report-container d-inline">
            <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#reportViolationModal" t-att-data-url="request.httprequest.url">
                <i class="fa fa-flag" aria-hidden="true"/> Report Violation
            </button>
        </div>
    </template>

    <template id="unsubscribe_success" name="Unsubscription Success">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <t t-call="website.layout">
            <div class="container mt-5 pt-5 text-center">
                <div class="card shadow-sm border-0 mx-auto" style="max-width: 600px;">
                    <div class="card-body p-5">
                        <i class="fa fa-check-circle text-success" style="font-size: 4rem;" aria-hidden="true"/>
                        <h2 class="mt-4 fw-bold">Unsubscribed Successfully</h2>
                        <p class="lead text-muted mt-3">
                            We successfully removed you from the mailing list for <strong t-out="record_name"/>.
                            You will no longer receive weekly digests for this site.
                        </p>
                        <a href="/" class="btn btn-primary mt-4">Return to Homepage</a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="documentation_page" name="User Websites Documentation">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_user_websites_backend_views_rendering] -->
        <t t-call="website.layout">
            <div class="container mt-5 mb-5 shadow-sm p-5 bg-white rounded">
                <div class="row">
                    <div class="col-12">
                        <h1 class="mb-4 fw-bold">User Websites Module Documentation</h1>
                        <p class="lead text-muted"><strong>Version:</strong> Odoo 19 Community<br/>
                        <strong>Summary:</strong> Enables decentralized, multi-tenant content creation within a single Odoo instance, allowing users to build personal or group-managed websites and blogs.</p>
                        <hr class="mt-4 mb-4"/>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="placeholder_page" name="Website Placeholder">
        <!-- Tested by [@ANCHOR: user_websites:test_tour_create_site] -->
        <t t-call="website.layout">
            <div class="container mt-5 mb-5 text-center">
                <t t-set="entity_name" t-value="profile_user.name if profile_user else profile_group.name"/>
                <t t-set="entity_slug" t-value="resolved_slug"/>

                <div class="card shadow-sm border-0 mx-auto" style="max-width: 600px;">
                    <div class="card-body p-5">
                        <i class="fa fa-globe text-muted mb-3" style="font-size: 4rem;" aria-hidden="true"/>
                        <t t-if="is_owner">
                            <t t-set="help_hash" t-value="'#UX_CREATE_SITE' if page_type == 'home' else '#UX_CREATE_BLOG_POST'"/>
                            <h2 class="fw-bold">Welcome, <t t-out="entity_name"/>! <a t-attf-href="/user-websites/documentation#{help_hash}" class="text-info fs-5 ms-1" title="Help"><i class="fa fa-question-circle" aria-hidden="true"/></a></h2>
                            <p class="text-muted mt-3 mb-4">
                                Your <t t-out="page_type"/> has not been initialized yet. Click the button below to generate your initial layout and start editing.
                            </p>
                            <form t-attf-action="/#{entity_slug}/create_#{'site' if page_type == 'home' else 'blog'}" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-primary btn-lg o_tour_create_site_btn">
                                    <i t-attf-class="fa #{'fa-paint-brush' if page_type == 'home' else 'fa-pencil'} me-2" aria-hidden="true"/>
                                    Create Your <span style="text-transform: capitalize;"><t t-out="page_type"/></span>
                                </button>
                            </form>
                        </t>
                        <t t-else="">
                            <h2 class="fw-bold text-muted"><t t-out="entity_name"/></h2>
                            <p class="text-muted mt-3">
                                This user has not yet created their <t t-out="page_type"/>. Please check back later!
                            </p>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
