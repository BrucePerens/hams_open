<odoo>
    <!-- Verified by [@ANCHOR: test_dropzone_settings] -->

    <record id="res_config_settings_view_form_inherit_user_websites" model="ir.ui.view"> 
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_dropzone_settings] -->
        <field name="name">res.config.settings.view.form.inherit.user.websites</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Verified by [@ANCHOR: test_dropzone_settings] -->
            <!-- audit-ignore-xpath: Tested by [@ANCHOR: test_dropzone_settings] -->
            <xpath expr="//form" position="inside"> 
                <div id="user_websites_dropzone_settings">
                    <!-- [@ANCHOR: dropzone_settings] -->
                </div>
                <app data-string="User Websites" string="User Websites" name="user_websites" data-key="user_websites">
                    <block title="User Websites Management" id="user_websites_management">
                        <setting help="Select users who can manage all user sites and violation reports.">
                            <field name="user_websites_administrators_ids" widget="many2many_tags"/>
                        </setting>
                        <setting help="Default maximum number of web pages a standard user can create.">
                            <field name="global_website_page_limit"/>
                        </setting>
                        <setting help="Email address where content violation reports will be sent.">
                            <field name="company_abuse_email" placeholder="abuse@yourcompany.com"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
