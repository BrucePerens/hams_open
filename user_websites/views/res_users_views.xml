<odoo>
    <record id="view_users_form_user_websites" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_dropzone_users] -->
        <field name="name">res.users.form.user.websites</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Verified by [@ANCHOR: test_dropzone_users] -->
            <!-- audit-ignore-xpath: Tested by [@ANCHOR: test_dropzone_users] -->
            <xpath expr="//notebook" position="inside"> 
                <page string="User Websites" name="user_websites_settings">
                    <div id="user_websites_dropzone_users">
                        <!-- [@ANCHOR: dropzone_users] -->
                    </div>
                    <group>
                        <group>
                            <separator string="Configuration"/>
                            <field name="website_slug"/>
                            <field name="website_page_limit"/>
                            <field name="privacy_show_in_directory"/>
                        </group>
                        <group groups="user_websites.group_user_websites_administrator">
                            <separator string="Moderation &amp; Trust"/>
                            <field name="violation_strike_count"/>
                            <field name="is_suspended_from_websites" widget="boolean_toggle"/>
                            <div class="mt-2" invisible="not is_suspended_from_websites">
                                <span class="text-danger fw-bold"><i class="fa fa-ban" aria-hidden="true"/> User is currently suspended.</span>
                                <button name="action_pardon_user_websites" string="Pardon &amp; Lift Suspension" type="object" class="btn-link text-success ms-2" invisible="not id"/>
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
