<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_database_management" model="res.groups.privilege">
            <field name="name">Database Management</field>
            <field name="category_id" ref="base.module_category_administration"/>
        </record>

        <record id="group_database_management_manager" model="res.groups">
            <field name="name">Database Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_database_management"/>
            <field name="comment">Users with this privilege can manage database statistics, active sessions, and PostgreSQL configurations.</field>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="name">Settings</field>
            <field name="implied_ids" eval="[(4, ref('database_management.group_database_management_manager'))]"/>
        </record>
    </data>
    <data>
        <record id="user_database_management_service" model="res.users">
            <field name="name">Database Management Service Account</field>
            <field name="login">user_database_management_service</field>
            <field name="email">dbmgt@hams.local</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('database_management.group_database_management_manager')])]"/>
        </record>
    </data>
</odoo>
