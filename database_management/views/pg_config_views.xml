<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pg_setting_list" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_pg_config_views] -->
        <field name="name">database.pg.setting.list</field>
        <field name="model">database.pg.setting</field>
        <field name="arch" type="xml">
            <list string="PostgreSQL Configuration" create="false" edit="false" decoration-warning="pending_restart == True">
                <field name="name"/>
                <field name="setting"/>
                <field name="unit"/>
                <field name="category" optional="hide"/>
                <field name="short_desc"/>
                <field name="pending_restart" widget="boolean"/>
            </list>
        </field>
    </record>

    <record id="view_pg_optimize_wizard_form" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_pg_config_views] -->
        <field name="name">pg.optimize.wizard.form</field>
        <field name="model">pg.optimize.wizard</field>
        <field name="arch" type="xml">
            <form string="Database Optimization Wizard">
                <div class="alert alert-info" role="alert">
                    This wizard will automatically calculate and apply optimal PostgreSQL settings (work_mem, shared_buffers, parallel workers) based on your hardware. Values are written safely to <strong>postgresql.auto.conf</strong> via ALTER SYSTEM.
                </div>
                <group>
                    <group>
                        <field name="ram_gb"/>
                        <field name="cpu_cores"/>
                    </group>
                    <group>
                        <field name="storage_type"/>
                        <field name="max_connections"/>
                    </group>
                </group>
                <footer>
                    <button name="action_apply_optimizations" type="object" string="Calculate &amp; Apply Optimizations" class="btn-danger" confirm="This will modify your core database configuration. You must manually restart the PostgreSQL service afterward for shared memory changes to take effect. Proceed?"/>
                    <button special="cancel" string="Cancel" class="btn-secondary o_tour_cancel_btn"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_pg_ha_wizard_form" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_pg_config_views] -->
        <field name="name">pg.ha.wizard.form</field>
        <field name="model">pg.ha.wizard</field>
        <field name="arch" type="xml">
            <form string="High Availability Failover Wizard">
                <div class="alert alert-warning" role="alert" invisible="state == 'generated'">
                    To achieve enterprise High Availability, Hams.com utilizes <strong>Patroni</strong> (for automated failover and etcd leader election) and <strong>PgBouncer</strong> (for connection pooling). Enter your bare-metal topology below to generate the exact YAML configuration files required for your system administrators.
                </div>
                <sheet>
                    <field name="state" invisible="1"/>
                    <group invisible="state == 'generated'">
                        <group>
                            <field name="cluster_name"/>
                            <field name="primary_ip"/>
                            <field name="secondary_ip"/>
                            <field name="etcd_hosts"/>
                        </group>
                        <group>
                            <field name="replication_user"/>
                            <field name="replication_pass" password="True"/>
                            <field name="superuser_user"/>
                        </group>
                    </group>
                    <notebook invisible="state == 'input'">
                        <page string="Primary Node (Patroni)">
                            <field name="patroni_primary" widget="CopyClipboardText"/>
                        </page>
                        <page string="Secondary Node (Patroni)">
                            <field name="patroni_secondary" widget="CopyClipboardText"/>
                        </page>
                        <page string="Connection Pooler (PgBouncer)">
                            <field name="pgbouncer_ini" widget="CopyClipboardText"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_generate" type="object" string="Generate Configurations" class="btn-primary" invisible="state == 'generated'"/>
                    <button special="cancel" string="Close" class="btn-secondary o_tour_close_btn"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pg_setting" model="ir.actions.act_window">
        <field name="name">PostgreSQL Configuration</field>
        <field name="res_model">database.pg.setting</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_pg_optimize_wizard" model="ir.actions.act_window">
        <field name="name">Optimization Wizard</field>
        <field name="res_model">pg.optimize.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_pg_ha_wizard" model="ir.actions.act_window">
        <field name="name">HA Failover Orchestrator</field>
        <field name="res_model">pg.ha.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
