<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_db_table_stat_list" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_dba_view] -->
        <field name="name">database.table.stat.list</field>
        <field name="model">database.table.stat</field>
        <field name="arch" type="xml">
            <list string="Table Health" create="false" edit="false">
                <header>
                    <button name="action_vacuum_analyze" type="object" string="Vacuum Analyze Selected" class="btn-danger"/>
                </header>
                <field name="table_name"/>
                <field name="total_size_mb" sum="Total Size"/>
                <field name="live_tuples" sum="Total Rows"/>
                <field name="dead_tuples"/>
                <field name="dead_percent" widget="progressbar"/>
                <field name="cache_hit_percent" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="view_db_query_stat_list" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_dba_view] -->
        <field name="name">database.query.stat.list</field>
        <field name="model">database.query.stat</field>
        <field name="arch" type="xml">
            <list string="Slow Queries" create="false" edit="false">
                <header>
                    <button name="action_install_extension" type="object" string="Install / Fix Extension" class="btn-info"/>
                </header>
                <field name="query"/>
                <field name="calls" sum="Executions"/>
                <field name="total_time" sum="Total Load"/>
                <field name="mean_time"/>
                <button name="action_explain_query" type="object" string="Explain" icon="fa-search-plus" title="Analyze Query Performance"/>
            </list>
        </field>
    </record>

    <record id="view_pg_explain_wizard_form" model="ir.ui.view"> <!-- audit-ignore-view -->
        <field name="name">pg.explain.wizard.form</field>
        <field name="model">pg.explain.wizard</field>
        <field name="arch" type="xml">
            <form string="Explain Plan">
                <group>
                    <field name="query" widget="ace" options="{'mode': 'sql'}"/>
                    <field name="explain_plan" widget="ace" options="{'mode': 'text'}"/>
                </group>
                <footer>
                    <button name="action_close" string="Close" type="object" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_db_activity_list" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_dba_view] -->
        <field name="name">database.activity.list</field>
        <field name="model">database.activity</field>
        <field name="arch" type="xml">
            <list string="Active Sessions" create="false" edit="false" decoration-danger="duration > 60">
                <header>
                    <button name="action_terminate_backend" type="object" string="Kill Selected Queries" class="btn-danger" confirm="Are you sure you want to forcibly terminate these PostgreSQL backends?"/>
                </header>
                <field name="pid"/>
                <field name="usename"/>
                <field name="state"/>
                <field name="query"/>
                <field name="duration"/>
            </list>
        </field>
    </record>

    <record id="view_db_index_stat_list" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_dba_view] -->
        <field name="name">database.index.stat.list</field>
        <field name="model">database.index.stat</field>
        <field name="arch" type="xml">
            <list string="Index Health" create="false" edit="false" decoration-warning="idx_scan == 0">
                <field name="table_name"/>
                <field name="index_name"/>
                <field name="idx_scan" sum="Total Scans"/>
                <field name="index_size_kb" sum="Total Index Size"/>
            </list>
        </field>
    </record>

    <record id="view_db_replication_stat_list" model="ir.ui.view"> <!-- audit-ignore-view -->
        <field name="name">database.replication.stat.list</field>
        <field name="model">database.replication.stat</field>
        <field name="arch" type="xml">
            <list string="Replication Status" create="false" edit="false">
                <field name="usename"/>
                <field name="application_name"/>
                <field name="client_addr"/>
                <field name="state"/>
                <field name="replay_lag"/>
                <field name="sync_state"/>
            </list>
        </field>
    </record>

    <record id="view_db_index_advisor_list" model="ir.ui.view"> <!-- audit-ignore-view -->
        <field name="name">database.index.advisor.list</field>
        <field name="model">database.index.advisor</field>
        <field name="arch" type="xml">
            <list string="Index Recommendations" create="false" edit="false">
                <field name="table_name"/>
                <field name="seq_scan" sum="Total Seq Scans"/>
                <field name="seq_tup_read" sum="Total Seq Tuples Read"/>
                <field name="idx_scan" sum="Total Index Scans"/>
                <field name="table_size_mb"/>
            </list>
        </field>
    </record>
</odoo>
