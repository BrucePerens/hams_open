<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_admin_root" name="Database &amp; SRE" sequence="70"/>

    <record id="action_db_table_stat" model="ir.actions.act_window">
        <field name="name">Table Health &amp; Bloat</field>
        <field name="res_model">database.table.stat</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_db_query_stat" model="ir.actions.act_window">
        <field name="name">Slow Query APM</field>
        <field name="res_model">database.query.stat</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_db_activity" model="ir.actions.act_window">
        <field name="name">Active Sessions (Kill Switch)</field>
        <field name="res_model">database.activity</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_db_index_stat" model="ir.actions.act_window">
        <field name="name">Index Health</field>
        <field name="res_model">database.index.stat</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_db_index_advisor" model="ir.actions.act_window">
        <field name="name">Index Advisor (Recommendations)</field>
        <field name="res_model">database.index.advisor</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_db_root" name="Database Health" parent="menu_admin_root" sequence="70"/>
    <menuitem id="menu_db_tables" name="Table Health &amp; Bloat" parent="menu_db_root" action="action_db_table_stat" sequence="10"/>
    <menuitem id="menu_db_indexes" name="Index Health" parent="menu_db_root" action="action_db_index_stat" sequence="20"/>
    <menuitem id="menu_db_index_advisor" name="Index Advisor" parent="menu_db_root" action="action_db_index_advisor" sequence="25"/>
    <menuitem id="menu_db_activity" name="Active Sessions" parent="menu_db_root" action="action_db_activity" sequence="30"/>
    <menuitem id="menu_db_queries" name="Slow Queries (APM)" parent="menu_db_root" action="action_db_query_stat" sequence="40"/>
    
    <menuitem id="menu_pg_config_root" name="Configuration &amp; Tuning" parent="menu_db_root" sequence="100"/>
    <menuitem id="menu_pg_settings" name="View Active Settings" parent="menu_pg_config_root" action="action_pg_setting" sequence="10"/>
    <menuitem id="menu_pg_optimize" name="Optimization Wizard" parent="menu_pg_config_root" action="action_pg_optimize_wizard" sequence="20"/>
    <menuitem id="menu_pg_ha" name="High Availability Orchestrator" parent="menu_pg_config_root" action="action_pg_ha_wizard" sequence="30"/>
</odoo>
