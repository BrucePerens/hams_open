<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- [@ANCHOR: otp_mail_template] -->
        <record id="email_template_official_otp" model="mail.template">
            <field name="name">Official OTP</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="subject">Your Verification OTP</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Your OTP is: <t t-out="object.official_otp"/></p>
                </div>
            </field>
        </record>
    </data>
</odoo>
