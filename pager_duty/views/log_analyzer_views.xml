<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Verified by [@ANCHOR: test_log_analyzer_views] -->
    <record id="view_pager_log_pattern_list" model="ir.ui.view">
        <field name="name">pager.log.pattern.list</field>
        <field name="model">pager.log.pattern</field>
        <field name="arch" type="xml">
            <list string="Log Regex Patterns" editable="bottom">
                <field name="name"/>
                <field name="regex"/>
                <field name="severity"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Verified by [@ANCHOR: test_log_analyzer_views] -->
    <record id="view_pager_log_file_list" model="ir.ui.view">
        <field name="name">pager.log.file.list</field>
        <field name="model">pager.log.file</field>
        <field name="arch" type="xml">
            <list string="Monitored Log Files" editable="bottom">
                <field name="filepath"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_pager_log_pattern" model="ir.actions.act_window">
        <field name="name">Log Anomaly Patterns</field>
        <field name="res_model">pager.log.pattern</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_pager_log_file" model="ir.actions.act_window">
        <field name="name">Monitored Log Files</field>
        <field name="res_model">pager.log.file</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_pager_log_analyzer_root" name="Log Analyzer" parent="menu_admin_root" sequence="50"/>
    <menuitem id="menu_pager_log_pattern" name="Regex Anomaly Patterns" parent="menu_pager_log_analyzer_root" action="action_pager_log_pattern" sequence="10"/>
    <menuitem id="menu_pager_log_file" name="Target Files" parent="menu_pager_log_analyzer_root" action="action_pager_log_file" sequence="20"/>

    <record id="action_pager_log_viewer_client" model="ir.actions.client">
        <field name="name">Interactive Log Search</field>
        <field name="tag">pager_duty.log_viewer</field>
    </record>
    <menuitem id="menu_pager_log_viewer" name="Search Logs (Splunk)" parent="menu_pager_log_analyzer_root" action="action_pager_log_viewer_client" sequence="5"/>
</odoo>
