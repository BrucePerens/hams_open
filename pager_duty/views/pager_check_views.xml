<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pager_check_list" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_pager_view] -->
        <!-- burn-ignore-tour -->
        <field name="name">pager.check.list</field>
        <field name="model">pager.check</field>
        <field name="arch" type="xml">
            <list string="Monitoring Checks" decoration-danger="status == 'failing'" decoration-warning="status == 'maintenance'" decoration-success="status == 'passing'">
                <header>
                    <button name="action_autodiscover" type="object" string="Auto-Discover Services" class="btn-info" confirm="This will scan your system and create new baseline checks for discovered daemons and hardware. Continue?"/>
                    <button name="action_pull_from_json" type="object" string="Pull from Daemon (JSON)" class="btn-secondary" confirm="This will overwrite your database checks with the current daemon JSON file. Continue?"/>
                    <button name="action_push_to_json" type="object" string="Push to Daemon (JSON)" class="btn-primary" confirm="This will write your current database checks to the daemon's JSON file and apply them. Continue?"/>
                </header>
                <field name="name"/>
                <field name="check_type"/>
                <field name="target"/>
                <field name="status"/>
                <field name="last_run"/>
            </list>
        </field>
    </record>
    <record id="view_pager_check_form" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_pager_view] -->
        <!-- TODO: A JS UI Tour MUST be created for this form due to dynamic invisible state logic (ADR 0076). Once created, add the tour link anchor here. -->
        <field name="name">pager.check.form</field>
        <field name="model">pager.check</field>
        <field name="arch" type="xml">
            <form string="Monitoring Check">
                <header>
                    <button name="action_trigger_check" type="object" string="Run Check Now" class="btn-primary"/>
                    <field name="status" widget="statusbar" statusbar_visible="passing,failing,maintenance"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Core Router Ping"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="check_type"/>
                            <field name="target" invisible="check_type == 'heartbeat'"/>
                            <field name="website_id" groups="website.group_multi_website"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="interval"/>
                            <field name="grace_period"/>
                            <field name="last_run" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Configuration">
                            <group>
                                <group>
                                    <field name="warning_threshold"/>
                                    <field name="critical_threshold"/>
                                    <field name="payload_expect" invisible="check_type not in ('http', 'http3', 'snmp')"/>
                                    <field name="parent_check_id"/>
                                        <field name="auto_remediate_script"/>
                                    </group>
                                    <group>
                                        <separator string="Documentation"/>
                                        <field name="comment" widget="text"/>
                                    </group>
                                <group>
                                    <separator string="Protocol Specifics"/>
                                    <field name="port" invisible="check_type not in ('tcp', 'udp', 'redis', 'rabbitmq', 'postgres')"/>
                                    <field name="dbname" invisible="check_type != 'postgres'"/>
                                    <field name="dbuser" invisible="check_type != 'postgres'"/>
                                    <field name="dbpass" password="True" invisible="check_type != 'postgres'"/>
                                    <field name="query" invisible="check_type not in ('anomaly', 'postgres')"/>
                                    <field name="payload_send" invisible="check_type not in ('tcp', 'udp')"/>
                                    <field name="payload_send_hex" invisible="check_type not in ('tcp', 'udp')"/>
                                    <field name="rpc_method" invisible="check_type not in ('xmlrpc', 'jsonrpc')"/>
                                    <field name="rpc_params" invisible="check_type not in ('xmlrpc', 'jsonrpc')"/>
                                    <field name="regex" invisible="check_type not in ('log', 'http', 'http3')"/>
                                    <field name="script" invisible="check_type != 'synthetic'"/>

                                    <field name="snmp_community" invisible="check_type != 'snmp'"/>
                                    <field name="snmp_oid" invisible="check_type != 'snmp'"/>
                                    <field name="partition" invisible="check_type != 'system'"/>
                                    <field name="ignored_services" invisible="check_type != 'systemd'"/>
                                </group>
                            </group>
                        </page>
                        <page string="Maintenance">
                            <group>
                                <field name="maintenance_start"/>
                                <field name="maintenance_end"/>
                            </group>
                        </page>
                        <page string="Synthetic &amp; Sandbox" invisible="check_type not in ('playwright', 'bash', 'executable')">
                            <div class="alert alert-info" role="alert">
                                <strong>Playwright:</strong> Enter Python Playwright code. <strong>Bash:</strong> Enter Bash script. <strong>Executable:</strong> Specify path to downloaded binary.<br/>
                                Bash and Executables are strictly airgapped and chrooted via Bubblewrap (bwrap).
                            </div>
                            <div class="alert alert-warning" role="alert" invisible="check_type != 'playwright' or sandbox_network_access != 'loopback'">
                                <i class="fa fa-info-circle me-1" title="Information"/> <strong>Loop-back only mode:</strong> only URLs with host address 127.0.0.1 or [::1] will work. Turn on full network mode if other host-names or addresses are necessary.
                            </div>
                            <group>
                                <field name="code_payload" widget="text" invisible="check_type not in ('playwright', 'bash')"/>
                                <field name="executable_path" invisible="check_type != 'executable'"/>
                                    <field name="executable_args" invisible="check_type != 'executable'"/>
                                    <field name="sandbox_downloads" widget="text" invisible="check_type not in ('bash', 'executable')" placeholder="https://example.com/bin | e3b0c44... | my_binary"/>
                                    <field name="sandbox_network_access" widget="radio" invisible="check_type not in ('playwright', 'bash', 'executable')"/>
                                </group>
                        </page>
                        <page string="Heartbeat Info" invisible="check_type != 'heartbeat'">
                            <group>
                                <field name="heartbeat_uuid"/>
                                <field name="last_heartbeat" readonly="1"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                Send a POST request to <code>/api/v1/pager/heartbeat/&lt;uuid&gt;</code> to keep this check passing.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pager_check" model="ir.actions.act_window">
        <field name="name">Monitoring Configuration</field>
        <field name="res_model">pager.check</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_pager_board" name="NOC Dashboard" parent="menu_admin_root" action="action_pager_board_client" sequence="10"/>
    <menuitem id="menu_pager_checks" name="Monitoring Checks" parent="menu_admin_root" action="action_pager_check" sequence="30"/>
</odoo>
