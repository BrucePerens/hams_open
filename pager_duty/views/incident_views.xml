<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pager_incident_list" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_pager_view] -->
        <field name="name">pager.incident.list</field>
        <field name="model">pager.incident</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="website_id" groups="base.group_no_one"/>
                <field name="source"/>
                <field name="severity"/>
                <field name="status"/>
                <field name="acknowledged_by_id" optional="show"/>
                <field name="mtta"/>
                <field name="mttr"/>
            </list>
        </field>
    </record>
    <record id="view_pager_incident_kanban" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_pager_view] -->
        <field name="name">pager.incident.kanban</field>
        <field name="model">pager.incident</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_mobile">
                <field name="name"/>
                <field name="source"/>
                <field name="severity"/>
                <field name="status"/>
                <field name="acknowledged_by_id"/>
                <field name="mtta"/>
                <field name="mttr"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <span t-if="record.severity.raw_value == 'critical'" class="badge text-bg-danger">Critical</span>
                                    <span t-elif="record.severity.raw_value == 'high'" class="badge text-bg-warning">High</span>
                                    <span t-elif="record.severity.raw_value == 'medium'" class="badge text-bg-info">Medium</span>
                                    <span t-else="" class="badge text-bg-secondary">Low</span>
                                    <field name="source" class="ms-2"/>
                                </div>
                                <div t-if="record.acknowledged_by_id.raw_value">
                                    Ack: <field name="acknowledged_by_id"/>
                                </div>
                                <div class="mt-2 text-muted" style="font-size: 0.8em;">
                                    <span t-if="record.mtta.raw_value">MTTA: <field name="mtta"/>m</span>
                                    <span t-if="record.mttr.raw_value" class="ms-2">MTTR: <field name="mttr"/>m</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_pager_board_client" model="ir.actions.client">
        <field name="name">NOC Dashboard</field>
        <field name="tag">pager_duty.board</field>
    </record>

    <record id="action_pager_incident" model="ir.actions.act_window">
        <field name="name">Pager Incidents</field>
        <field name="res_model">pager.incident</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_admin_root" name="Pager Duty" sequence="70"/>
    <menuitem id="menu_pager_incident" name="Incidents" parent="menu_admin_root" action="action_pager_incident" sequence="20"/>
</odoo>
