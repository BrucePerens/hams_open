[Unit]
Description=Pager Synthetic & Sandbox Execution Spooler
After=network.target

[Service]
Type=simple
# Requires root to execute bubblewrap with new user namespaces depending on OS constraints
User=root
# Removing group specification
WorkingDirectory=/opt/odoo/addons/pager_duty/daemon
ExecStart=/usr/bin/env python3 pager_synthetic_spooler.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
