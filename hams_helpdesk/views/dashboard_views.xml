<odoo>
    <record id="action_helpdesk_my_shift" model="ir.actions.act_window">
        <!-- burn-ignore-tour -->
        <field name="name">My Active Shift</field>
        <field name="res_model">hams_helpdesk.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_id', '=', uid), ('stage', 'in', ['new', 'in_progress'])]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                You currently have no active tickets for this shift.
            </p>
        </field>
    </record>

    <record id="view_hams_helpdesk_ticket_pivot" model="ir.ui.view">
        <!-- burn-ignore-tour -->
        <!-- audit-ignore-view: Tested by [@ANCHOR: helpdesk_operator_tour] -->
        <field name="name">hams_helpdesk.ticket.pivot</field>
        <field name="model">hams_helpdesk.ticket</field>
        <field name="arch" type="xml">
            <pivot string="Ticket Analysis">
                <field name="user_id" type="row"/>
                <field name="stage" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="action_helpdesk_management_audit" model="ir.actions.act_window">
        <!-- burn-ignore-tour -->
        <field name="name">Management Audit</field>
        <field name="res_model">hams_helpdesk.ticket</field>
        <field name="view_mode">pivot,list,form</field>
    </record>

    <menuitem id="menu_hams_helpdesk_my_shift" name="My Shift" parent="menu_hams_helpdesk_root" action="action_helpdesk_my_shift" sequence="5"/>
    <menuitem id="menu_hams_helpdesk_audit" name="Audit &amp; Reporting" parent="menu_hams_helpdesk_root" action="action_helpdesk_management_audit" sequence="20" groups="hams_helpdesk.group_helpdesk_manager"/>
</odoo>
