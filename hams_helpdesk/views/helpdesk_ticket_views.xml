<odoo>
    <record id="view_hams_helpdesk_ticket_form" model="ir.ui.view">
        <!-- [@ANCHOR: COMM_helpdesk_ticket_form] -->
        <field name="name">hams_helpdesk.ticket.form</field>
        <field name="model">hams_helpdesk.ticket</field>
        <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_helpdesk_operator_tour] -->
        <field name="arch" type="xml">
            <form string="Helpdesk Ticket">
                <header>
                    <button name="action_shift_handoff" string="Shift Handoff" type="object" class="oe_highlight" invisible="not id or stage in ('resolved', 'closed')"/>
                    <field name="stage" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="callsign"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="priority" widget="priority"/>
                            <field name="calendar_event_id"/>
                            <field name="website_id" groups="base.group_no_one"/>
                            <field name="company_id" invisible="1"/>
                            <field name="ticket_type"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_hams_helpdesk_ticket_list" model="ir.ui.view">
        <!-- [@ANCHOR: COMM_helpdesk_ticket_list] -->
        <field name="name">hams_helpdesk.ticket.list</field>
        <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_helpdesk_operator_tour] -->
        <field name="model">hams_helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list string="Helpdesk Tickets">
                <field name="name"/>
                <field name="callsign"/>
                <field name="user_id"/>
                <field name="stage"/>
                <field name="priority" widget="priority"/>
            </list>
        </field>
    </record>

    <record id="action_hams_helpdesk_ticket" model="ir.actions.act_window">
        <!-- burn-ignore-tour -->
        <field name="name">Helpdesk Tickets</field>
        <field name="res_model">hams_helpdesk.ticket</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hams_helpdesk_root" name="Helpdesk" sequence="50"/>
    <menuitem id="menu_hams_helpdesk_tickets" name="Tickets" parent="menu_hams_helpdesk_root" action="action_hams_helpdesk_ticket" sequence="10"/>
</odoo>
