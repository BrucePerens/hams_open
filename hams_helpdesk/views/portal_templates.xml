<odoo>
    <template id="portal_my_home_menu_helpdesk" name="Portal layout : helpdesk menu entries" inherit_id="portal.portal_breadcrumbs" priority="20">
        <!-- burn-ignore-tour -->
        <!-- audit-ignore-xpath: Tested by [@ANCHOR: COMM_helpdesk_portal_tour] -->
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'ticket' or ticket" class="breadcrumb-item">
                <a t-if="ticket" t-attf-href="/my/tickets?{{ keep_query() }}">Tickets</a>
                <t t-else="">Tickets</t>
            </li>
            <li t-if="ticket" class="breadcrumb-item active">
                <t t-out="ticket.name"/>
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_helpdesk" name="Show Tickets" inherit_id="portal.portal_my_home" priority="20">
        <!-- burn-ignore-tour -->
        <!-- audit-ignore-xpath: Tested by [@ANCHOR: COMM_helpdesk_portal_tour] -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Helpdesk Tickets</t>
                <t t-set="url" t-value="'/my/tickets'"/>
                <t t-set="placeholder_count" t-value="'ticket_count'"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_tickets" name="My Tickets">
        <!-- [@ANCHOR: COMM_helpdesk_portal_list] -->
        <t t-call="portal.portal_layout">
            <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_helpdesk_portal_tour] -->
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Tickets</t>
                <div class="ms-md-auto">
                    <a href="/my/tickets/new" class="btn btn-primary o_tour_new_ticket">New Ticket</a>
                </div>
            </t>
            <t t-if="not tickets">
                <p>There are currently no tickets for your account.</p>
            </t>
            <t t-if="tickets" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Ticket #</th>
                        <th>Title</th>
                        <th>Callsign</th>
                        <th class="text-center">Priority</th>
                        <th class="text-end">Stage</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="tickets" t-as="t">
                        <td><a t-attf-href="/my/ticket/#{t.id}"><t t-out="t.id"/></a></td>
                        <td><a t-attf-href="/my/ticket/#{t.id}"><t t-out="t.name"/></a></td>
                        <td><t t-out="t.callsign"/></td>
                        <td class="text-center">
                            <t t-if="t.priority == '3'"><span class="badge rounded-pill text-bg-danger">Critical</span></t>
                            <t t-elif="t.priority == '2'"><span class="badge rounded-pill text-bg-warning">High</span></t>
                            <t t-elif="t.priority == '1'"><span class="badge rounded-pill text-bg-info">Medium</span></t>
                            <t t-else=""><span class="badge rounded-pill text-bg-secondary">Low</span></t>
                        </td>
                        <td class="text-end"><span class="badge rounded-pill text-bg-info"><t t-out="dict(t._fields['stage'].selection).get(t.stage)"/></span></td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_ticket_detail" name="Ticket Detail">
        <!-- [@ANCHOR: COMM_helpdesk_portal_detail] -->
        <t t-call="portal.portal_layout">
            <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_helpdesk_portal_tour] -->
            <div id="optional_classes" class="container">
                <div class="card mt-3">
                    <div class="card-header bg-light">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h3 class="mb-0"><span t-field="ticket.name"/></h3>
                            </div>
                            <div class="col-md-4 text-end">
                                <form t-if="ticket.stage != 'closed'" t-attf-action="/my/ticket/#{ticket.id}/close" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-warning btn-sm o_tour_close_ticket">Close Ticket</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div><strong>Status:</strong> <span class="badge rounded-pill text-bg-info o_helpdesk_status_badge" t-field="ticket.stage"/></div>
                                <div t-if="ticket.callsign"><strong>Callsign:</strong> <span class="o_helpdesk_callsign" t-field="ticket.callsign"/></div>
                            </div>
                            <div class="col-md-6 text-end">
                                <strong>Priority:</strong>
                                <t t-if="ticket.priority == '3'"><span class="badge rounded-pill text-bg-danger">Critical</span></t>
                                <t t-elif="ticket.priority == '2'"><span class="badge rounded-pill text-bg-warning">High</span></t>
                                <t t-elif="ticket.priority == '1'"><span class="badge rounded-pill text-bg-info">Medium</span></t>
                                <t t-else=""><span class="badge rounded-pill text-bg-secondary">Low</span></t>
                            </div>
                        </div>
                        <hr/>
                        <div t-field="ticket.description"/>
                    </div>
                </div>

                <div class="mt-5">
                    <h4>Communication History</h4>
                    <t t-call="portal.message_thread">
                        <t t-set="object" t-value="ticket"/>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_ticket_new" name="New Ticket">
        <!-- [@ANCHOR: COMM_helpdesk_portal_new] -->
        <t t-call="portal.portal_layout">
            <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_helpdesk_portal_tour] -->
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card mt-3">
                            <div class="card-header">
                                <h3>Submit New Ticket</h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted mb-4">
                                    Please provide a clear subject and detailed description of the issue you are experiencing.
                                    An on-duty engineer will be assigned to assist you shortly.
                                </p>
                                <form action="/my/tickets/submit" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="mb-3">
                                        <label for="name" class="form-label">Subject</label>
                                        <input type="text" name="name" id="name" class="form-control" required="required" placeholder="Short summary of the issue"/>
                                    </div>
                                    <div class="mb-3">
                                        <label for="callsign" class="form-label">Callsign</label>
                                        <input type="text" name="callsign" id="callsign" class="form-control" t-att-value="default_callsign" placeholder="Your callsign (if applicable)"/>
                                    </div>
                                    <div class="mb-3">
                                        <label for="description" class="form-label">Description</label>
                                        <textarea name="description" id="description" class="form-control" rows="5" placeholder="Detailed steps to reproduce, error messages, or context..."></textarea>
                                    </div>
                                    <div class="text-end">
                                        <button type="submit" class="btn btn-primary o_tour_submit_ticket">Submit Ticket</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
