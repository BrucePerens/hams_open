<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="res.groups.privilege" id="privilege_helpdesk">
            <field name="name">Helpdesk Access</field>
            <field name="category_id" ref="base.module_category_operations_helpdesk"/>
        </record>

        <record id="group_helpdesk_user" model="res.groups">
            <field name="name">Helpdesk User</field>
            <field name="privilege_id" ref="privilege_helpdesk"/>
        </record>

        <record id="group_helpdesk_manager" model="res.groups">
            <field name="name">Helpdesk Manager</field>
            <field name="privilege_id" ref="privilege_helpdesk"/>
            <field name="implied_ids" eval="[(4, ref('group_helpdesk_user'))]"/>
        </record>

        <record id="rule_helpdesk_ticket_user" model="ir.rule">
            <field name="name">Helpdesk Ticket User</field>
            <field name="model_id" ref="model_hams_helpdesk_ticket"/>
            <field name="domain_force">['&amp;', '|', ('user_id', '=', user.id), ('user_id', '=', False), '|', ('website_id', '=', False), ('website_id', '=', user.website_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_user'))]"/>
        </record>

        <record id="rule_helpdesk_ticket_manager" model="ir.rule">
            <field name="name">Helpdesk Ticket Manager</field>
            <field name="model_id" ref="model_hams_helpdesk_ticket"/>
            <field name="domain_force">['|', ('website_id', '=', False), ('website_id', '=', user.website_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_manager'))]"/>
        </record>

        <record id="rule_helpdesk_ticket_portal" model="ir.rule">
            <field name="name">Helpdesk Ticket Portal</field>
            <field name="model_id" ref="model_hams_helpdesk_ticket"/>
            <field name="domain_force">['&amp;', '&amp;', ('partner_id', '=', user.partner_id.id), '|', ('website_id', '=', False), ('website_id', '=', user.website_id.id), ('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="rule_helpdesk_ticket_multicompany" model="ir.rule">
            <field name="name">Helpdesk Ticket Multi-Company</field>
            <field name="model_id" ref="model_hams_helpdesk_ticket"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_user'))]"/>
        </record>
    </data>
    <data>
        <!-- Helpdesk Service Account for automated tasks -->
        <record id="user_helpdesk_service" model="res.users">
            <field name="name">Helpdesk Service Account</field>
            <field name="login">helpdesk_service_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('group_helpdesk_manager'), ref('base.group_user')])]"/>
        </record>
    </data>
</odoo>
