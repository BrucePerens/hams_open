<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Verified by [@ANCHOR: test_binary_manifest_views] -->
    <record id="view_binary_downloader_manifest_list" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: test_binary_manifest_views] -->
        <field name="name">binary.manifest.list</field>
        <field name="model">binary.manifest</field>
        <field name="arch" type="xml">
            <list string="Binary Manifests">
                <field name="name"/>
                <field name="archive_type"/>
                <field name="url"/>
                <field name="checksum"/>
                <field name="is_installed"/>
                <button name="action_install" type="object" string="Install" icon="fa-download" class="btn-primary" invisible="is_installed" groups="binary_downloader.group_binary_downloader_manager,base.group_system"/>
            </list>
        </field>
    </record>

    <!-- Verified by [@ANCHOR: test_binary_manifest_views] -->
    <record id="view_binary_downloader_manifest_form" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: test_binary_manifest_views] -->
        <field name="name">binary.manifest.form</field>
        <field name="model">binary.manifest</field>
        <field name="arch" type="xml">
            <form string="Binary Manifest">
                <header>
                    <!-- [@ANCHOR: UX_BINARY_INSTALL] -->
                    <button name="action_install" type="object" string="Install Now" class="oe_highlight" invisible="is_installed or not id" groups="binary_downloader.group_binary_downloader_manager,base.group_system"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g., kopia"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="is_installed" readonly="1"/>
                            <field name="archive_type"/>
                            <field name="extract_member" invisible="archive_type != 'tar.gz'"/>
                        </group>
                        <group>
                            <field name="url"/>
                            <field name="checksum"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_binary_downloader_manifest" model="ir.actions.act_window">
        <field name="name">Binary Manifests</field>
        <field name="res_model">binary.manifest</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_binary_downloader_manifest"
              name="Binary Manifests"
              action="action_binary_downloader_manifest"
              sequence="150"/>
</odoo>
