<odoo>
    <data noupdate="1">
        <record model="res.groups.privilege" id="privilege_caching_service">
            <field name="name">Caching Service</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_caching_service" model="res.groups">
            <field name="name">Caching Service Account Group</field>
            <field name="privilege_id" ref="privilege_caching_service"/>
        </record>

        <record id="rule_caching_service_config_param" model="ir.rule">
            <field name="name">Caching Service Config Param Rule</field>
            <field name="model_id" ref="base.model_ir_config_parameter"/>
            <field name="domain_force">[('key', '=like', 'caching.%')]</field>
            <field name="groups" eval="[(4, ref('caching.group_caching_service'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
    <data>
        <record id="user_caching_service" model="res.users">
            <field name="name">Caching Service User</field>
            <field name="login">caching_service_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('caching.group_caching_service')])]"/>
        </record>
    </data>
</odoo>
