<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="res.groups.privilege" id="privilege_caching_service">
            <field name="name">Caching Service</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_caching_service" model="res.groups">
            <field name="name">Caching Service Account Group</field>
            <field name="privilege_id" ref="privilege_caching_service"/>
        </record>

        <record id="user_caching_service" model="res.users">
            <field name="name">Caching Service User</field>
            <field name="login">caching_service_internal</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('caching.group_caching_service')])]"/>
        </record>
    </data>
</odoo>
