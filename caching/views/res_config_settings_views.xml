<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <!-- [@ANCHOR: COMM_xpath_rendering_caching_settings] -->

        <!-- Verified by [@ANCHOR: test_xpath_rendering_caching_settings] -->

        <!-- burn-ignore-tour -->
        <field name="name">res.config.settings.view.form.inherit.caching</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- audit-ignore-xpath: Tested by [@ANCHOR: test_xpath_rendering_caching_settings] -->
            <xpath expr="//block[@id='website_settings']" position="after">
                <block title="Caching Service Worker" id="caching_settings">
                    <setting string="Safe Quota" help="Configure the browser storage limit (in MB) for the service worker.">
                        <field name="caching_safe_quota_mb" class="o_light_label" widget="integer"/>
                        <span>MB</span>
                    </setting>
                    <setting string="Force Cache Invalidation" help="Manually invalidate the service worker cache for all clients.">
                        <div class="text-muted mt8"><span>Current Version: </span><field name="caching_invalidation_version" class="fw-bold"/></div>
                        <div class="mt8">
                            <button name="action_force_cache_invalidation" type="object" string="Invalidate Cache Now" class="btn btn-primary" icon="fa-refresh" title="Invalidate Cache Now"/>
                        </div>
                    </setting>
                    <setting string="PWA Theme Color" help="Set the theme color for the PWA Manifest.">
                        <field name="caching_pwa_theme_color" widget="color"/>
                    </setting>
                    <setting string="PWA Background Color" help="Set the background color for the PWA Manifest.">
                        <field name="caching_pwa_background_color" widget="color"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
