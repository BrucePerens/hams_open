<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="zero_sudo.SecurityDashboard">
        <div class="o_security_dashboard overflow-auto p-4 h-100 bg-view">
            <h1 class="mb-4">Security Dashboard</h1>
            <div class="table-responsive border bg-white shadow-sm rounded">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Target User</th>
                            <th>Login</th>
                            <th>IP Address</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="state.logs || []" t-as="log" t-key="log.id">
                            <td t-out="log.create_date"/>
                            <td t-out="log.user_id ? log.user_id[1] : ''"/>
                            <td t-out="log.login"/>
                            <td t-out="log.ip_address"/>
                            <td t-out="log.reason"/>
                        </tr>
                        <tr t-if="!state.logs.length">
                            <td colspan="5" class="text-center py-4 text-muted">
                                No security logs found.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>
