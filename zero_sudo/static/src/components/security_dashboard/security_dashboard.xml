<templates xml:space="preserve">
    <t t-name="zero_sudo.SecurityDashboard">
        <div class="o_security_dashboard overflow-auto p-4 h-100 bg-dark text-white" style="transition: transform 20s linear;" t-ref="dashboardRoot" t-att-aria-live="state.isPaused ? 'off' : 'polite'">
            <h1 class="mb-4">
                Security Dashboard <a class="o_doc_link" href="/zero_sudo/documentation#COMM_UX_centralized_security_logs" target="_blank"><i class="fa fa-question-circle" role="img" aria-label="Help" title="Help"/></a>
                <button class="btn btn-sm btn-outline-light ms-3 o_security_dashboard_pause" t-on-click="togglePause" t-att-aria-label="state.isPaused ? 'Resume updates' : 'Pause updates'" t-att-title="state.isPaused ? 'Resume updates' : 'Pause updates'">
                    <i t-attf-class="fa #{state.isPaused ? 'fa-play' : 'fa-pause'}" role="presentation"/>
                    <span class="ms-1" t-out="state.isPaused ? 'Resume' : 'Pause'"/>
                </button>
            </h1>
            <div class="table-responsive border bg-dark text-white shadow-sm rounded">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th>
                            <th>Target User</th>
                            <th>Login</th>
                            <th>IP Address</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="state.logs || []" t-as="log" t-key="log.id">
                            <td t-out="log.create_date"/>
                            <td t-out="log.user_id ? log.user_id[1] : ''"/>
                            <td t-out="log.login"/>
                            <td t-out="log.ip_address"/>
                            <td t-out="log.reason"/>
                        </tr>
                        <tr t-if="!state.logs.length">
                            <td colspan="5" class="text-center py-4 text-muted">
                                No security logs found.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>
