<odoo>
    <record id="view_noisy_table_list" model="ir.ui.view">
        <!-- burn-ignore-tour: Tested by [@ANCHOR: zero_sudo:COMM_test_noisy_table_views] -->
        <field name="name">zero_sudo.noisy_table.list</field>
        <field name="model">zero_sudo.noisy_table</field>
        <field name="arch" type="xml">
            <list string="Noisy Tables">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_noisy_table_form" model="ir.ui.view">
        <!-- burn-ignore-tour: Tested by [@ANCHOR: zero_sudo:COMM_test_noisy_table_views] -->
        <field name="name">zero_sudo.noisy_table.form</field>
        <field name="model">zero_sudo.noisy_table</field>
        <field name="arch" type="xml">
            <form string="Noisy Table">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_noisy_table" model="ir.actions.act_window">
        <field name="name">Noisy Tables</field>
        <field name="res_model">zero_sudo.noisy_table</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a new noisy table
            </p>
            <p>
                Noisy tables are ignored by the Real Transaction Testing Facility leak detector.
            </p>
        </field>
    </record>

    <!-- [@ANCHOR: zero_sudo:COMM_UX_NOISY_TABLE_MANAGEMENT] -->
    <menuitem id="menu_noisy_table"
              name="Noisy Tables"
              parent="base.menu_administration"
              action="action_noisy_table"
              sequence="100"/>
</odoo>
