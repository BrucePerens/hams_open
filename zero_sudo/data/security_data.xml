<odoo>
    <data noupdate="1">
        <record model="res.groups.privilege" id="privilege_zero_sudo">
            <field name="name">Zero Sudo Services</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_mail_service" model="res.groups">
            <field name="name">Central Mail Service Group</field>
            <field name="privilege_id" ref="privilege_zero_sudo"/>
        </record>

        <record id="group_odoo_facility_service" model="res.groups">
            <field name="name">Odoo Facility Service Group</field>
            <field name="privilege_id" ref="privilege_zero_sudo"/>
        </record>

        <record id="group_config_service" model="res.groups">
            <field name="name">Central Configuration Service Group</field>
            <field name="privilege_id" ref="privilege_zero_sudo"/>
        </record>

        <record id="group_cache_invalidator" model="res.groups">
            <field name="name">Central Cache Invalidation Group</field>
            <field name="privilege_id" ref="privilege_zero_sudo"/>
        </record>
    </data>
    <data>
        <record id="mail_service_internal" model="res.users">
            <field name="name">Central Mail Service Account</field>
            <field name="login">mail_service_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('zero_sudo.group_mail_service')])]"/>
        </record>

        <record id="odoo_facility_service_internal" model="res.users">
            <field name="name">Odoo Facility Service Account</field>
            <field name="login">odoo_facility_service_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('zero_sudo.group_odoo_facility_service'), ref('base.group_user')])]"/>
        </record>

        <record id="config_service_internal" model="res.users">
            <field name="name">Central Configuration Service Account</field>
            <field name="login">config_service_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('zero_sudo.group_config_service')])]"/>
        </record>

        <record id="cache_invalidation_service_internal" model="res.users">
            <field name="name">Central Cache Invalidation Service Account</field>
            <field name="login">cache_invalidation_service_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('zero_sudo.group_cache_invalidator')])]"/>
        </record>

    </data>
</odoo>
