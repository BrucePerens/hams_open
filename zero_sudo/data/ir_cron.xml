<odoo>
    <data noupdate="1">
        <record id="ir_cron_security_log_autovacuum" model="ir.cron">
            <!-- audit-ignore-cron: Tested by [@ANCHOR: zero_sudo:COMM_test_security_log_autovacuum] -->
            <field name="name">Security Log: Autovacuum</field>
            <field name="model_id" ref="model_zero_sudo_security_log"/>
            <field name="state">code</field>
            <field name="code">model.autovacuum()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="user_id" ref="zero_sudo.odoo_facility_service_internal"/>

        </record>
    </data>
