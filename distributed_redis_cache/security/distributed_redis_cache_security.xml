<odoo>
    <data noupdate="1">
        <record model="ir.module.category" id="module_category_distributed_redis_cache">
            <field name="name">Distributed Redis Cache</field>
            <field name="description">Access rights for the Distributed Redis Cache.</field>
            <field name="sequence">60</field>
        </record>

        <record model="res.groups.privilege" id="privilege_distributed_redis_cache">
            <field name="name">Cache Management</field>
            <field name="category_id" ref="module_category_distributed_redis_cache"/>
        </record>

        <record id="group_distributed_cache_manager" model="res.groups">
            <field name="name">Cache Manager</field>
            <field name="privilege_id" ref="privilege_distributed_redis_cache"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_cache_manager_service" model="res.groups">
            <field name="name">Service Account: Redis Cache Manager</field>
        </record>
    </data>
    <data>
        <record id="cache_manager_service_internal" model="res.users">
            <field name="name">Redis Cache Manager</field>
            <field name="login">cache_manager_sys</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('distributed_redis_cache.group_cache_manager_service')])]"/>
        </record>
    </data>
</odoo>
