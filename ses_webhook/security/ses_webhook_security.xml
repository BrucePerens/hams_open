<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Multi-Company Rule for Domains -->
        <record id="ses_webhook_domain_comp_rule" model="ir.rule">
            <field name="name">SES Webhook Domain Multi-Company</field>
            <field name="model_id" ref="model_ses_webhook_domain"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Multi-Company Rule for Logs -->
        <record id="ses_webhook_log_comp_rule" model="ir.rule">
            <field name="name">SES Webhook Log Multi-Company</field>
            <field name="model_id" ref="model_ses_webhook_log"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
