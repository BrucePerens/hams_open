<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_user_websites_seo" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: test_xpath_rendering_res_users] -->
        <field name="name">res.users.form.user.websites.seo</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="user_websites.view_users_form_user_websites"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='user_websites_settings']" position="after"> <!-- audit-ignore-xpath: Tested by [@ANCHOR: COMM_test_xpath_rendering_res_users] -->
                <page string="SEO Metadata" name="user_websites_seo_settings">
                    <group>
                        <group>
                            <separator string="SEO Data"/>
                            <field name="seo_name"/>
                            <field name="website_meta_title"/>
                            <field name="website_meta_description"/>
                            <field name="website_meta_keywords"/>
                        </group>
                        <group>
                            <separator string="Social Media"/>
                            <field name="website_meta_og_img"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
