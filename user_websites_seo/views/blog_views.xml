<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_blog_post_form_seo" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: test_xpath_rendering_pages_posts] -->
        <field name="name">blog.post.form.seo</field>
        <field name="model">blog.post</field>
        <field name="inherit_id" ref="website_blog.view_blog_post_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside"> <!-- audit-ignore-xpath: Tested by [@ANCHOR: COMM_test_xpath_rendering_pages_posts] -->
                <page string="SEO Metadata" name="seo_settings">
                    <group>
                        <group>
                            <separator string="SEO Data"/>
                            <field name="seo_name"/>
                            <field name="website_meta_title"/>
                            <field name="website_meta_description"/>
                            <field name="website_meta_keywords"/>
                        </group>
                        <group>
                            <separator string="Social Media"/>
                            <field name="website_meta_og_img"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_blog_blog_form_seo" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [@ANCHOR: test_xpath_rendering_pages_posts] -->
        <field name="name">blog.blog.form.seo</field>
        <field name="model">blog.blog</field>
        <field name="inherit_id" ref="website_blog.view_blog_blog_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside"> <!-- audit-ignore-xpath: Tested by [@ANCHOR: COMM_test_xpath_rendering_pages_posts] -->
                <notebook>
                    <page string="SEO Metadata" name="seo_settings">
                        <group>
                            <group>
                                <separator string="SEO Data"/>
                                <field name="seo_name"/>
                                <field name="website_meta_title"/>
                                <field name="website_meta_description"/>
                                <field name="website_meta_keywords"/>
                            </group>
                            <group>
                                <separator string="Social Media"/>
                                <field name="website_meta_og_img"/>
                            </group>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
