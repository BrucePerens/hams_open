<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cloudflare.AnalyticsDashboard" owl="1">
        <div class="o_cloudflare_analytics_dashboard p-4">
            <h1>Cloudflare Analytics</h1>
            <div t-if="state.loading" class="text-muted">
                Loading analytics data...
            </div>
            <div t-else="" class="row mt-4">
                <div class="col-md-4">
                    <div class="card bg-primary text-white">
                        <div class="card-body">
                            <h5 class="card-title">Total Requests</h5>
                            <h2 class="card-text"><t t-out="state.requests"/></h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <h5 class="card-title">Bandwidth Served</h5>
                            <h2 class="card-text"><t t-out="state.bandwidth"/></h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-danger text-white">
                        <div class="card-body">
                            <h5 class="card-title">Threats Blocked</h5>
                            <h2 class="card-text"><t t-out="state.threats"/></h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
