<odoo>
    <!-- Verified by [@ANCHOR: test_tour_cf_purge_wizard] -->
    <record id="view_cloudflare_purge_wizard_form" model="ir.ui.view">
        <field name="name">cloudflare.purge.wizard.form</field>
        <field name="model">cloudflare.purge.wizard</field>
        <field name="arch" type="xml">
            <form string="Manual Cache Purge">
                <sheet>
                    <group>
                        <field name="website_id" groups="website.group_multi_website"/>
                        <field name="purge_type"/>
                        <field name="items_to_purge" invisible="purge_type == 'everything'" required="purge_type != 'everything'"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Purge" name="action_purge" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cf_purge_wizard" model="ir.actions.act_window">
        <field name="name">Manual Cache Purge</field>
        <field name="res_model">cloudflare.purge.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_cf_purge_wizard" name="Manual Cache Purge" parent="menu_cloudflare_root" action="action_cf_purge_wizard" sequence="40"/>
</odoo>
