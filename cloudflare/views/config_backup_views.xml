<odoo>
    <record id="view_cloudflare_config_backup_list" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_cf_backend_views_rendering] -->
        <field name="name">cloudflare.config.backup.list</field>
        <field name="model">cloudflare.config.backup</field>
        <field name="arch" type="xml">
            <list string="Config Backups" create="false" edit="false">
                <field name="create_date"/>
                <field name="name"/>
                <field name="website_id" groups="website.group_multi_website" optional="show"/>
                <field name="phase"/>
            </list>
        </field>
    </record>
    <record id="view_cloudflare_config_backup_form" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_cf_backend_views_rendering] -->
        <field name="name">cloudflare.config.backup.form</field>
        <field name="model">cloudflare.config.backup</field>
        <field name="arch" type="xml">
            <form string="Configuration Backup" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="website_id" groups="website.group_multi_website"/>
                        <field name="create_date"/>
                        <field name="phase"/>
                    </group>
                    <notebook>
                        <page string="Raw Cloudflare Payload">
                            <field name="raw_json" widget="code" options="{'mode': 'application/json'}" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_cf_config_backup" model="ir.actions.act_window">
        <field name="name">Configuration Backups</field>
        <field name="res_model">cloudflare.config.backup</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_cf_config_backups" name="Configuration Backups" parent="menu_cloudflare_root" action="action_cf_config_backup" sequence="30"/>
</odoo>
