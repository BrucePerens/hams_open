<odoo>
    <record id="view_cloudflare_zone_settings_wizard_form" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_tour_cf_zone_settings] -->
        <field name="name">cloudflare.zone.settings.wizard.form</field>
        <field name="model">cloudflare.zone.settings.wizard</field>
        <field name="arch" type="xml">
            <form string="Zone Settings">
                <sheet>
                    <group>
                        <group>
                            <field name="website_id" groups="website.group_multi_website"/>
                            <field name="security_level"/>
                        </group>
                        <group>
                            <field name="development_mode"/>
                            <field name="browser_cache_ttl"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Apply Settings" name="action_apply_settings" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cf_zone_settings_wizard" model="ir.actions.act_window">
        <field name="name">Zone Settings</field>
        <field name="res_model">cloudflare.zone.settings.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_cf_zone_settings" name="Zone Settings" parent="menu_cloudflare_root" action="action_cf_zone_settings_wizard" sequence="50"/>
</odoo>
