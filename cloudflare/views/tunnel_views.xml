<odoo>
    <record id="view_cloudflare_tunnel_list" model="ir.ui.view">
        <!-- burn-ignore-tour -->
        <!-- audit-ignore-view: Tested by [@ANCHOR: COMM_test_cf_sync_tunnels] -->
        <field name="name">cloudflare.tunnel.list</field>
        <field name="model">cloudflare.tunnel</field>
        <field name="arch" type="xml">
            <list string="Tunnels" create="false" edit="false">
                <header>
                    <button name="action_sync_tunnels" type="object" string="Sync Tunnels" class="btn-primary"/>
                </header>
                <field name="name"/>
                <field name="cf_tunnel_id"/>
                <field name="status"/>
                <field name="created_at"/>
                <field name="website_id" groups="website.group_multi_website" optional="show"/>
                <button name="action_delete_tunnel" type="object" icon="fa-trash" string="Delete Tunnel" confirm="Are you sure you want to delete this tunnel from Cloudflare?"/>
            </list>
        </field>
    </record>

    <record id="view_cloudflare_tunnel_form" model="ir.ui.view">
        <field name="name">cloudflare.tunnel.form</field>
        <field name="model">cloudflare.tunnel</field>
        <field name="arch" type="xml">
            <form string="Tunnel Configuration">
                <header>
                    <button name="action_push_configuration" type="object" string="Push Routing Config" class="btn-primary" confirm="This will push the local routing table to Cloudflare. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="cf_tunnel_id" readonly="1"/>
                            <field name="status" readonly="1"/>
                            <field name="website_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Routing Table (Ingress Rules)">
                            <field name="route_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="hostname" placeholder="e.g. api.hams.com"/>
                                    <field name="path" placeholder="e.g. /adif"/>
                                    <field name="service_url" placeholder="e.g. http://localhost:8070"/>
                                </list>
                            </field>
                            <div class="text-muted mt-2">
                                Note: A catch-all rule pointing to Odoo (http://localhost:8069) is automatically appended when pushing to Cloudflare.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cf_tunnel" model="ir.actions.act_window">
        <field name="name">Cloudflare Tunnels</field>
        <field name="res_model">cloudflare.tunnel</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_cf_tunnels" name="Tunnels" parent="menu_cloudflare_root" action="action_cf_tunnel" sequence="60"/>
</odoo>
