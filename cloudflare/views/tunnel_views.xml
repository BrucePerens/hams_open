<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Verified by [@ANCHOR: test_cf_sync_tunnels] -->
    <record id="view_cloudflare_tunnel_list" model="ir.ui.view">
        <field name="name">cloudflare.tunnel.list</field>
        <field name="model">cloudflare.tunnel</field>
        <field name="arch" type="xml">
            <list string="Tunnels" create="false" edit="false">
                <header>
                    <button name="action_sync_tunnels" type="object" string="Sync Tunnels" class="btn-primary"/>
                </header>
                <field name="name"/>
                <field name="cf_tunnel_id"/>
                <field name="status"/>
                <field name="created_at"/>
                <field name="website_id" groups="website.group_multi_website" optional="show"/>
                <button name="action_delete_tunnel" type="object" icon="fa-trash" string="Delete Tunnel" confirm="Are you sure you want to delete this tunnel from Cloudflare?"/>
            </list>
        </field>
    </record>

    <record id="action_cf_tunnel" model="ir.actions.act_window">
        <field name="name">Cloudflare Tunnels</field>
        <field name="res_model">cloudflare.tunnel</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_cf_tunnels" name="Tunnels" parent="menu_cloudflare_root" action="action_cf_tunnel" sequence="60"/>
</odoo>
