<odoo>
    <data noupdate="1">
        <!-- Purge Service -->
        <record id="group_cloudflare_purge" model="res.groups">
            <field name="name">Cloudflare Edge: Purge Service</field>
        </record>

        <!-- WAF Service -->
        <record id="group_cloudflare_waf" model="res.groups">
            <field name="name">Cloudflare Edge: WAF Service</field>
        </record>

        <!-- Tunnel Service -->
        <record id="group_cloudflare_tunnel" model="res.groups">
            <field name="name">Cloudflare Edge: Tunnel Service</field>
        </record>

        <!-- Deprecated monolithic service group (kept for legacy ref compatibility but emptied) -->
        <record id="group_cloudflare_service" model="res.groups">
            <field name="name">Cloudflare Edge Service Account (Deprecated)</field>
        </record>
    </data>
    <data>
        <record id="user_cloudflare_purge" model="res.users">
            <field name="name">Cloudflare Purge Service</field>
            <field name="login">cloudflare_purge_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('cloudflare.group_cloudflare_purge')])]"/>
        </record>

        <record id="user_cloudflare_waf" model="res.users">
            <field name="name">Cloudflare WAF Service</field>
            <field name="login">cloudflare_waf_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('cloudflare.group_cloudflare_waf')])]"/>
        </record>

        <record id="user_cloudflare_tunnel" model="res.users">
            <field name="name">Cloudflare Tunnel Service</field>
            <field name="login">cloudflare_tunnel_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('cloudflare.group_cloudflare_tunnel')])]"/>
        </record>

        <record id="user_cloudflare_service" model="res.users">
            <field name="name">Cloudflare Queue Service (Deprecated)</field>
            <field name="login">cloudflare_service_internal</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="False"/>
            <field name="group_ids" eval="[(6, 0, [])]"/>
        </record>
    </data>

    <data noupdate="1">
        <!-- Multi-Tenant Record Rules -->
        <record id="cloudflare_purge_queue_rule" model="ir.rule">
            <field name="name">Cloudflare Purge Queue: Website Isolation</field>
            <field name="model_id" ref="model_cloudflare_purge_queue"/>
            <field name="domain_force">['|', ('website_id', '=', False), '|', ('website_id.company_id', 'in', company_ids), ('website_id.company_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="cloudflare_waf_rule_rule" model="ir.rule">
            <field name="name">Cloudflare WAF Rule: Website Isolation</field>
            <field name="model_id" ref="model_cloudflare_waf_rule"/>
            <field name="domain_force">['|', ('website_id.company_id', 'in', company_ids), ('website_id.company_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="cloudflare_ip_ban_rule" model="ir.rule">
            <field name="name">Cloudflare IP Ban: Website Isolation</field>
            <field name="model_id" ref="model_cloudflare_ip_ban"/>
            <field name="domain_force">['|', ('website_id.company_id', 'in', company_ids), ('website_id.company_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="cloudflare_config_backup_rule" model="ir.rule">
            <field name="name">Cloudflare Config Backup: Website Isolation</field>
            <field name="model_id" ref="model_cloudflare_config_backup"/>
            <field name="domain_force">['|', ('website_id.company_id', 'in', company_ids), ('website_id.company_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="cloudflare_tunnel_rule" model="ir.rule">
            <field name="name">Cloudflare Tunnel: Website Isolation</field>
            <field name="model_id" ref="model_cloudflare_tunnel"/>
            <field name="domain_force">['|', ('website_id.company_id', 'in', company_ids), ('website_id.company_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Service Account Global Access (Bypass isolation for operations) -->
        <record id="cloudflare_purge_queue_rule_service" model="ir.rule">
            <field name="name">Cloudflare Purge Queue: Service Account Global</field>
            <field name="model_id" ref="model_cloudflare_purge_queue"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('cloudflare.group_cloudflare_purge'))]"/>
        </record>

        <record id="cloudflare_waf_rule_rule_service" model="ir.rule">
            <field name="name">Cloudflare WAF Rule: Service Account Global</field>
            <field name="model_id" ref="model_cloudflare_waf_rule"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('cloudflare.group_cloudflare_waf'))]"/>
        </record>

        <record id="cloudflare_ip_ban_rule_service" model="ir.rule">
            <field name="name">Cloudflare IP Ban: Service Account Global</field>
            <field name="model_id" ref="model_cloudflare_ip_ban"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('cloudflare.group_cloudflare_waf'))]"/>
        </record>

        <record id="cloudflare_tunnel_rule_service" model="ir.rule">
            <field name="name">Cloudflare Tunnel: Service Account Global</field>
            <field name="model_id" ref="model_cloudflare_tunnel"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('cloudflare.group_cloudflare_tunnel'))]"/>
        </record>
    </data>
</odoo>
